generator client {
  provider = "prisma-client-js"
}

// PostgreSQL (hosted, multi-user). The schema keeps the provider-agnostic shape
// the desktop SQLite build used — enum-like fields are String (validated by zod
// at the API boundary; canonical lists in src/lib/labels.ts) and JSON-shaped
// fields (paraMap, rects, linkedCardIds, tags) are String columns holding JSON
// text ((de)serialized by src/lib/jsonFields.ts) — so the app code is identical
// on either database.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Auth (Auth.js Prisma adapter) ----

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  matters   Matter[]
  apiTokens ApiToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Matter {
  id         String @id @default(cuid())
  /// owner — every matter is private to the user who created it
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  court      String @default("")
  caseNumber String @default("")
  parties    String @default("")
  /// OurSide: PETITIONER_PLAINTIFF | RESPONDENT_DEFENDANT | OTHER
  ourSide    String @default("OTHER")
  /// MatterStatus: ACTIVE | ARCHIVED
  status     String @default("ACTIVE")
  /// per-matter switch to disable AI features (confidentiality restrictions)
  aiEnabled  Boolean @default(true)
  /// annexure label prefix, e.g. "P" or "R"; empty = derive from ourSide
  annexurePrefix String @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("local")

  documents         Document[]
  cards             Card[]
  chronologyEntries ChronologyEntry[]
  traverseSheet     TraverseSheet?
  artefacts         GeneratedArtefact[]
  annexureItems     AnnexureItem[]

  @@index([userId])
}

model Document {
  id            String   @id @default(cuid())
  matterId      String
  matter        Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  filename      String
  /// DocType: PLAINT | WRITTEN_STATEMENT | PETITION | REPLY | REJOINDER | JUDGMENT | ORDER | ANNEXURE | CORRESPONDENCE | MISC
  docType       String   @default("MISC")
  annexureLabel String?
  storagePath   String
  pageCount     Int      @default(0)
  hasTextLayer  Boolean  @default(true)
  /// JSON text: list of { label: string, page: number, y: number } paragraph markers in reading order
  paraMap       String   @default("[]")
  status        String   @default("ready")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String   @default("local")

  pages DocumentPage[]
  cards Card[]

  @@index([matterId])
}

model DocumentPage {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  page       Int
  text       String

  @@unique([documentId, page])
}

model Card {
  id         String    @id @default(cuid())
  matterId   String
  matter     Matter    @relation(fields: [matterId], references: [id], onDelete: Cascade)
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  page       Int?
  para       String?
  /// exact highlighted source text
  quote      String    @default("")
  /// JSON text: normalized highlight rects [{ page, x, y, w, h }] with 0..1 coords
  rects      String    @default("[]")
  /// web captures (browser extension): source page URL + title
  sourceUrl   String?
  sourceTitle String?

  /// CardType: FACT | DATE | ISSUE | OUR_ARGUMENT | THEIR_ARGUMENT | EVIDENCE | CASE_LAW | ADMISSION | QUESTION | MISC
  cardType  String    @default("MISC")
  body      String    @default("")
  eventDate DateTime?
  /// JSON text: string[] of tags
  tags      String    @default("[]")
  pinned    Boolean   @default(false)

  citation    String?
  proposition String?
  /// Treatment: RELIED_ON | DISTINGUISHED | OVERRULED_RISK (nullable)
  treatment   String?

  orderIndex Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("local")

  chronologyEntries ChronologyEntry[]

  @@index([matterId, cardType])
  @@index([documentId])
}

model TraverseSheet {
  id         String   @id @default(cuid())
  matterId   String   @unique
  matter     Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  documentId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("local")

  rows TraverseRow[]
}

model TraverseRow {
  id           String        @id @default(cuid())
  sheetId      String
  sheet        TraverseSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  order        Int
  paraNo       String
  paraText     String
  /// rich text (HTML) reply
  responseText String        @default("")
  /// TraverseStatus: NOT_STARTED | DENIED_BARE | DENIED_SPECIFIC | ADMITTED | ADMITTED_PARTLY | LEGAL_OBJECTION
  status       String        @default("NOT_STARTED")
  /// JSON text: ids of Fact/Evidence cards attached to this row
  linkedCardIds String       @default("[]")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([sheetId, order])
}

model GeneratedArtefact {
  id             String   @id @default(cuid())
  matterId       String
  matter         Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  /// ArtefactType: SENIOR_BRIEF | WRITTEN_SUBMISSIONS | JUDGE_NOTE | LIST_OF_DATES | CONVENIENCE_COMPILATION | WRITTEN_STATEMENT_DRAFT
  artefactType   String
  title          String
  /// rich text (HTML) content
  content        String   @default("")
  version        Int      @default(1)
  /// prompt snapshot for AI-generated versions
  promptSnapshot String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String   @default("local")

  @@index([matterId, artefactType])
}

/// Annexure registry: ordered mapping of documents to labels (PRD F8).
/// Labels are computed from position + the matter's prefix and mirrored to
/// Document.annexureLabel on every renumber.
model AnnexureItem {
  id         String   @id @default(cuid())
  matterId   String
  matter     Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  documentId String   @unique
  position   Int
  createdAt  DateTime @default(now())

  @@index([matterId, position])
}

/// Bearer tokens for cross-origin clients (browser extension, remote add-ins).
/// Each token belongs to a user; requests it authenticates act as that user.
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([userId])
}

model ChronologyEntry {
  id              String   @id @default(cuid())
  matterId        String
  matter          Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  eventDate       DateTime
  description     String
  sourceCardId    String?  @unique
  sourceCard      Card?    @relation(fields: [sourceCardId], references: [id], onDelete: Cascade)
  includeInFiling Boolean  @default(true)
  sortOrder       Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String   @default("local")

  @@index([matterId, eventDate])
}
