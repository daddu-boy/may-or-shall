generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma-pg-client"
}

datasource db {
  provider = "postgresql"
  url      = env("PG_URL")
}

enum OurSide {
  PETITIONER_PLAINTIFF
  RESPONDENT_DEFENDANT
  OTHER
}

enum MatterStatus {
  ACTIVE
  ARCHIVED
}

enum DocType {
  PLAINT
  WRITTEN_STATEMENT
  PETITION
  REPLY
  REJOINDER
  JUDGMENT
  ORDER
  ANNEXURE
  CORRESPONDENCE
  MISC
}

enum CardType {
  FACT
  DATE
  ISSUE
  OUR_ARGUMENT
  THEIR_ARGUMENT
  EVIDENCE
  CASE_LAW
  ADMISSION
  QUESTION
  MISC
}

enum Treatment {
  RELIED_ON
  DISTINGUISHED
  OVERRULED_RISK
}

enum TraverseStatus {
  NOT_STARTED
  DENIED_BARE
  DENIED_SPECIFIC
  ADMITTED
  ADMITTED_PARTLY
  LEGAL_OBJECTION
}

enum ArtefactType {
  SENIOR_BRIEF
  WRITTEN_SUBMISSIONS
  JUDGE_NOTE
  LIST_OF_DATES
  CONVENIENCE_COMPILATION
  WRITTEN_STATEMENT_DRAFT
}

model Matter {
  id         String       @id @default(cuid())
  title      String
  court      String       @default("")
  caseNumber String       @default("")
  parties    String       @default("")
  ourSide    OurSide      @default(OTHER)
  status     MatterStatus @default(ACTIVE)
  /// per-matter switch to disable AI features (confidentiality restrictions)
  aiEnabled  Boolean      @default(true)
  /// annexure label prefix, e.g. "P" or "R"; empty = derive from ourSide
  annexurePrefix String   @default("")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  createdBy  String       @default("local")

  documents         Document[]
  cards             Card[]
  chronologyEntries ChronologyEntry[]
  traverseSheet     TraverseSheet?
  artefacts         GeneratedArtefact[]
  annexureItems     AnnexureItem[]
}

model Document {
  id            String   @id @default(cuid())
  matterId      String
  matter        Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  filename      String
  docType       DocType  @default(MISC)
  annexureLabel String?
  storagePath   String
  pageCount     Int      @default(0)
  hasTextLayer  Boolean  @default(true)
  /// list of { label: string, page: number, y: number } paragraph markers in reading order
  paraMap       Json     @default("[]")
  status        String   @default("ready")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String   @default("local")

  pages DocumentPage[]
  cards Card[]

  @@index([matterId])
}

model DocumentPage {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  page       Int
  text       String

  @@unique([documentId, page])
}

model Card {
  id         String    @id @default(cuid())
  matterId   String
  matter     Matter    @relation(fields: [matterId], references: [id], onDelete: Cascade)
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  page       Int?
  para       String?
  /// exact highlighted source text
  quote      String    @default("")
  /// normalized highlight rects: [{ page, x, y, w, h }] with 0..1 coords
  rects      Json      @default("[]")
  /// web captures (browser extension): source page URL + title
  sourceUrl   String?
  sourceTitle String?

  cardType  CardType  @default(MISC)
  body      String    @default("")
  eventDate DateTime? @db.Date
  tags      String[]  @default([])
  pinned    Boolean   @default(false)

  citation    String?
  proposition String?
  treatment   Treatment?

  orderIndex Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("local")

  chronologyEntries ChronologyEntry[]

  @@index([matterId, cardType])
  @@index([documentId])
}

model TraverseSheet {
  id         String   @id @default(cuid())
  matterId   String   @unique
  matter     Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  documentId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("local")

  rows TraverseRow[]
}

model TraverseRow {
  id           String         @id @default(cuid())
  sheetId      String
  sheet        TraverseSheet  @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  order        Int
  paraNo       String
  paraText     String
  /// rich text (HTML) reply
  responseText String         @default("")
  status       TraverseStatus @default(NOT_STARTED)
  /// ids of Fact/Evidence cards attached to this row
  linkedCardIds Json          @default("[]")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([sheetId, order])
}

model GeneratedArtefact {
  id             String       @id @default(cuid())
  matterId       String
  matter         Matter       @relation(fields: [matterId], references: [id], onDelete: Cascade)
  artefactType   ArtefactType
  title          String
  /// rich text (HTML) content
  content        String       @default("")
  version        Int          @default(1)
  /// prompt snapshot for AI-generated versions
  promptSnapshot String       @default("")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      String       @default("local")

  @@index([matterId, artefactType])
}

/// Annexure registry: ordered mapping of documents to labels (PRD F8).
/// Labels are computed from position + the matter's prefix and mirrored to
/// Document.annexureLabel on every renumber.
model AnnexureItem {
  id         String   @id @default(cuid())
  matterId   String
  matter     Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  documentId String   @unique
  position   Int
  createdAt  DateTime @default(now())

  @@index([matterId, position])
}

/// Bearer tokens for cross-origin clients (browser extension, remote add-ins).
model ApiToken {
  id         String    @id @default(cuid())
  name       String
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
}

model ChronologyEntry {
  id              String   @id @default(cuid())
  matterId        String
  matter          Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  eventDate       DateTime @db.Date
  description     String
  sourceCardId    String?  @unique
  sourceCard      Card?    @relation(fields: [sourceCardId], references: [id], onDelete: Cascade)
  includeInFiling Boolean  @default(true)
  sortOrder       Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String   @default("local")

  @@index([matterId, eventDate])
}
